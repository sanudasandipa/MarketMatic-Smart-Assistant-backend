# Environment Variables – Smart Assistant Backend

PORT=8000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/smart_assistant
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# Frontend origin allowed by CORS (your Next.js URL)
FRONTEND_URL=http://localhost:3000

# ── Ollama (local LLM & embedding server) ────────────────────────────────────
# When using docker-compose the URL is overridden to http://ollama:11434
# For local dev run:  ollama serve
OLLAMA_URL=http://localhost:11434
# Chat model (must be pulled: ollama pull phi3)
OLLAMA_CHAT_MODEL=phi3
# Embedding model (must be pulled: ollama pull nomic-embed-text)
OLLAMA_EMBED_MODEL=nomic-embed-text
# How long (ms) to wait for Ollama before falling back to Groq (default 60 s in Docker, 25 s local)
OLLAMA_TIMEOUT_MS=25000

# ── ChromaDB (vector store) ───────────────────────────────────────────────────
# When using docker-compose the URL is overridden to http://chroma:8000
CHROMA_URL=http://localhost:8001

# ── Groq API (cloud LLM fallback — used when Ollama is unavailable) ──────────
# Leave blank to disable the fallback (ragService will throw if Ollama also fails)
# Get a free key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ── Remote embedding fallback (optional) ─────────────────────────────────────
# Set to an OpenAI-compatible /v1/embeddings endpoint to use if Ollama fails
REMOTE_EMBED_URL=
REMOTE_EMBED_MODEL=nomic-embed-text
REMOTE_EMBED_KEY=

# ── RAG tuning ────────────────────────────────────────────────────────────────
# Cosine distance threshold: chunks above this value are discarded (0–2 scale)
# Lower = stricter relevance. Default 0.50 works well for most cases.
RAG_RELEVANCE_THRESHOLD=0.50

# ── MongoDB Docker credentials (used by docker-compose.yml only) ─────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASS=change_this_strong_password

# ── Superadmin seed credentials (used by seedSuperadmin.js only) ─────────────
SUPERADMIN_EMAIL=superadmin@platform.com
SUPERADMIN_PASSWORD=SuperAdmin@2024
SUPERADMIN_NAME=Platform Superadmin
